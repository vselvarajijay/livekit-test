# LiveKit server (WebSocket URL)
LIVEKIT_URL=ws://127.0.0.1:7880

# API credentials — must match LiveKit server (see README Docker example: LIVEKIT_KEYS="devkey: ...")
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdevsecret

# Room name — must match between publisher and operator UI
LIVEKIT_ROOM=robot

# Comma-separated ROS 2 topic names (sensor_msgs/CompressedImage, H.264 payload)
ROS2_VIDEO_TOPICS=/camera/front/h264,/camera/arm/h264

# Optional: LiveKit identity for the robot publisher
# LIVEKIT_PUBLISHER_IDENTITY=robot

# Optional: ROS 2 DDS domain id (default 0 if unset)
# ROS_DOMAIN_ID=0

# Frontend dev only — safe to expose; default WebSocket URL in the Vite app (see frontend/.env.example)
# VITE_LIVEKIT_URL=ws://127.0.0.1:7880
